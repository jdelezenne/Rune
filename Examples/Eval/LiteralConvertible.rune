struct Score implements IntegerLiteralConvertible {
    var points: Int

    public init(integerLiteral: Int) {
        self.points = integerLiteral
    }
}

struct Label implements StringLiteralConvertible {
    var text: String

    public init(stringLiteral: String) {
        self.text = stringLiteral
    }
}

struct Bag<T> {
    var count: Int
}

extension Bag<T> implements ArrayLiteralConvertible {
    public type Element = T

    public init(elements: T...) {
        self.count = elements.count
    }
}

struct IntStack {
    var values: Array<Int>
}

extension IntStack implements ArrayLiteralConvertible {
    public type Element = Int
    public init(elements: Int...) {
        self.values = []
        for i in 0..elements.count {
            self.values.append(elements[i])
        }
    }
}

func buildScore() -> Score {
    return 100
}

func buildLabel() -> Label {
    return "rune"
}

func buildBag() -> Bag<Int> {
    return [10, 20, 30]
}

func buildStack() -> IntStack {
    return [4, 5, 6]
}

func main() -> Int {
    const score = eval buildScore()
    if score.points != 100 {
        return 1
    }

    const label = eval buildLabel()
    if label.text.length != 4 {
        return 2
    }

    const bag = eval buildBag()
    if bag.count != 3 {
        return 3
    }

    const stack = eval buildStack()
    if stack.values.count != 3 {
        return 4
    }
    if stack.values[0] + stack.values[1] + stack.values[2] != 15 {
        return 5
    }

    return 0
}
