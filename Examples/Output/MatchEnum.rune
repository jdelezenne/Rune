import Standard.*

enum Color: UInt32 {
    red
    green
    blue
}

func describe(color: Color) -> String {
    match color {
        .red => return "red"
        .green => return "green"
        .blue => return "blue"
    }
}

func main() -> Int {
    Console.printLine(describe(Color.green))
    return 0
}
