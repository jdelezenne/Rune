}

struct Game {
    var ship: Ship
    var bullets: [Bullet]
    var asteroids: [Asteroid]
    var particles: [Particle]
    var stars: [Star]
    var score: Int32
    var lives: Int32
    var wave: Int32
    var pendingWave: Bool
    var paused: Bool
    var gameOver: Bool
    var rng: Rng
    var trailPrimed: Bool
}


func seedRng(rng: &Rng, seed: UInt32) {
    if seed == 0 {
        rng.state = 0xC0FFEE01
    } else {
        rng.state = seed
    }
}

func randUnit(rng: &Rng) -> Float32 {
    rng.state = rng.state * 1664525 + 1013904223
    return Float32(rng.state) / 4294967295.0
}

func randRange(rng: &Rng, low: Float32, high: Float32) -> Float32 {
    return low + randUnit(rng) * (high - low)
}

func randInt(rng: &Rng, upperExclusive: Int32) -> Int32 {
    if upperExclusive <= 0 {
        return 0
    }

    return Int32(randUnit(rng) * Float32(upperExclusive))
}

func wrapCoord(value: Float32, limit: Float32) -> Float32 {
    var v = value
    while v < 0.0 {
        v = v + limit
    }
    while v >= limit {
        v = v - limit
    }

    return v
}

func wrapShip(ship: &Ship) {
    ship.x = wrapCoord(ship.x, Float32(WIDTH))
    ship.y = wrapCoord(ship.y, Float32(HEIGHT))
}

func wrapBullet(bullet: &Bullet) {
    bullet.x = wrapCoord(bullet.x, Float32(WIDTH))
    bullet.y = wrapCoord(bullet.y, Float32(HEIGHT))
}

func wrapAsteroid(asteroid: &Asteroid) {
    asteroid.x = wrapCoord(asteroid.x, Float32(WIDTH))
    asteroid.y = wrapCoord(asteroid.y, Float32(HEIGHT))
}
