}

struct Bullet {
    var x: Float32
    var y: Float32
    var vx: Float32
    var vy: Float32
    var life: Float32
    var active: Bool
}

struct Asteroid {
    var x: Float32
    var y: Float32
    var vx: Float32
    var vy: Float32
    var angle: Float32
    var spin: Float32
    var tier: Int32
    var alive: Bool
    var vertexCount: Int32
    var radii: [Float32, 12]
}

struct Particle {
    var x: Float32
    var y: Float32
    var vx: Float32
    var vy: Float32
    var life: Float32
    var maxLife: Float32
    var size: Float32
    var red: UInt8
    var green: UInt8
