const DIGIT_COLS: Int = 5
const DIGIT_ROWS: Int = 7
const HUD_PIXEL: Float32 = 3.0
const HUD_GAP: Float32 = 2.0

const AUDIO_RATE: Int32 = 11025
const AUDIO_FADE: Int = 180
const AUDIO_AMP: Float32 = 9000.0
const TAU_F: Float32 = 6.2831855
struct Rng {
    var state: UInt32
}

