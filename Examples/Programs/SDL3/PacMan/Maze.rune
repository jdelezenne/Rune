// MARK: - Board geometry (shared by movement and rendering)

const CELL: Float32 = 20.0
const BOARD_X: Float32 = 40.0
const BOARD_Y: Float32 = 74.0
const BOARD_W: Float32 = 560.0
const BOARD_H: Float32 = 620.0

const WIDTH: Int32 = 640
const HEIGHT: Int32 = 734

// MARK: - Tile queries

func tileIndex(col: Int, row: Int) -> Int {
    return row * MAZE_COLS + col
}

func wrapCol(col: Int) -> Int {
    if col < 0 {
        return MAZE_COLS - 1
    }

    if col >= MAZE_COLS {
        return 0
    }

    return col
}

func tileAt(col: Int, row: Int) -> UInt8 {
    if row < 0 || row >= MAZE_ROWS {
        return TILE_WALL
    }

    return MAZE_TILES[tileIndex(wrapCol(col), row)]
}

func isWallTile(col: Int, row: Int) -> Bool {
    return tileAt(col, row) == TILE_WALL
}

func isWalkableForGhost(col: Int, row: Int, canUseHouse: Bool) -> Bool {
    let tile = tileAt(col, row)
    if tile == TILE_WALL {
        return false
    }

    if (tile == TILE_DOOR || tile == TILE_HOUSE) && !canUseHouse {
        return false
    }

    return true
}

func isWalkableForPacMan(col: Int, row: Int) -> Bool {
    return tileAt(col, row) == TILE_PATH
}

func tileCenterX(col: Int) -> Float32 {
    return BOARD_X + (Float32(col) + 0.5) * CELL
}

func tileCenterY(row: Int) -> Float32 {
    return BOARD_Y + (Float32(row) + 0.5) * CELL
}
