// Maze: the board layout and tile queries.
//
// This is the actual 1980 arcade maze topology: outer border, comb-tooth
// corridors, the center ghost house with its door, the single mid-board
// tunnel row that wraps left/right, and the four corner power pellets.
// Reconstructed by decoding a Tiled-format tilemap of the classic layout
// (base64+zlib tile grid), reducing it to wall/path/door/house-interior
// tile kinds, pruning unreachable background cells via flood fill from a
// known corridor tile, and verifying the result is fully connected and
// left-right symmetric.

import Standard.*

const MAZE_COLS: Int = 28
const MAZE_ROWS: Int = 31
const MAZE_CELLS: Int = 868

// Tile kinds.
const TILE_PATH: UInt8 = 0
const TILE_WALL: UInt8 = 1
const TILE_DOOR: UInt8 = 2
const TILE_HOUSE: UInt8 = 3

// Dot kinds.
const DOT_NONE: UInt8 = 0
const DOT_SMALL: UInt8 = 1
const DOT_POWER: UInt8 = 2

const TUNNEL_ROW: Int = 14

