// Stage 5 - the forest: tree cover hiding the lanes, with two still ponds.
const STAGE_5: [UInt8, GRID_CELLS] = [
    0, 0, 0, 3, 3, 3, 0, 3, 3, 3, 0, 0, 0,
    0, 1, 3, 3, 1, 3, 3, 3, 1, 3, 3, 1, 0,
    0, 3, 3, 1, 0, 3, 1, 3, 0, 1, 3, 3, 0,
