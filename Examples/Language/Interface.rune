interface Shape {
}

struct Rectangle implements Shape {
    var width: Int
    var height: Int
}

struct Square implements Shape {
    var side: Int
}

func main() -> Int {
    let rect = Rectangle(width: 6, height: 4)
    let square = Square(side: 5)
    if rect.width != 6 || rect.height != 4 || square.side != 5 {
        return 1
    }
    return 0
}
