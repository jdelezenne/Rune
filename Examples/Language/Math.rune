import Standard.*

func main() -> Int {
    let angle = Math.PI / 2.0
    let value = Math.sin(angle)
    let root = Math.sqrt(144.0)

    let deg90 = Math.radians(90.0)
    let rad90 = Math.degrees(Math.PI / 2.0)

    if value > 0.9 && value < 1.1 && root == 12.0 &&
       deg90 > 1.57 && deg90 < 1.58 &&
       rad90 > 89.9 && rad90 < 90.1 {
        return 0
    }

    return 1
}
