struct Counter {
    var value: Int

    mutating func increment() {
        value = value + 1
    }

    func get() -> Int {
        return value
    }
}

func incrementTwice(counter: &Counter) {
    counter.increment()
    counter.increment()
}

func main() -> Int {
    var counter = Counter(value: 0)
    incrementTwice(&counter)
    if counter.get() != 2 {
        return 1
    }

    return 0
}
