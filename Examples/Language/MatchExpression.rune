func classify(value: Int) -> Int {
    let result = match value {
        0 => 10
        1 => 20
        _ => 30
    }

    return result
}

func main() -> Int {
    let first = classify(0)
    let other = classify(4)

    let enabled = true
    let score = match enabled {
        true => 7
        false => 3
        _ => -1
    }

    if first != 10 {
        return 1
    }

    if other != 30 {
        return 2
    }

    if score != 7 {
        return 3
    }

    return 0
}
