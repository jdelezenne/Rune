func divide(a: Int, b: Int) throws -> Int {
    if b == 0 {
        throw
    }

    return a / b
}

func run() throws -> Int {
    return try divide(20, 4)
}

func main() -> Int {
    try {
        if run() != 5 {
            return 1
        }

        return 0
    }
    catch {
        return 2
    }
}
