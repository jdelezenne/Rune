}

public extension UInt64 implements Comparable {
    @intrinsic
    public func compareTo(other: UInt64) -> Ordering
}

public extension UInt implements Comparable {
    @intrinsic
    public func compareTo(other: UInt) -> Ordering
}

public extension Float32 implements Comparable {
    @intrinsic
    public func compareTo(other: Float32) -> Ordering
}

public extension Float64 implements Comparable {
    @intrinsic
    public func compareTo(other: Float64) -> Ordering
}

public extension Bool implements Comparable {
    @intrinsic
    public func compareTo(other: Bool) -> Ordering
}

public extension Char implements Comparable {
    @intrinsic
    public func compareTo(other: Char) -> Ordering
}

// MARK: - Literal Conversion

public extension Int8 implements IntegerLiteralConvertible {
    @intrinsic
    public init(integerLiteral: IntegerLiteral)
}

public extension Int16 implements IntegerLiteralConvertible {
    @intrinsic
    public init(integerLiteral: IntegerLiteral)
}

public extension Int32 implements IntegerLiteralConvertible {
    @intrinsic
    public init(integerLiteral: IntegerLiteral)
}

public extension Int64 implements IntegerLiteralConvertible {
    @intrinsic
    public init(integerLiteral: IntegerLiteral)
}

public extension Int implements IntegerLiteralConvertible {
    @intrinsic
    public init(integerLiteral: IntegerLiteral)
}

public extension UInt8 implements IntegerLiteralConvertible {
    @intrinsic
    public init(integerLiteral: IntegerLiteral)
}

public extension UInt16 implements IntegerLiteralConvertible {
    @intrinsic
    public init(integerLiteral: IntegerLiteral)
}

public extension UInt32 implements IntegerLiteralConvertible {
    @intrinsic
    public init(integerLiteral: IntegerLiteral)
}

public extension UInt64 implements IntegerLiteralConvertible {
    @intrinsic
    public init(integerLiteral: IntegerLiteral)
}

public extension UInt implements IntegerLiteralConvertible {
    @intrinsic
    public init(integerLiteral: IntegerLiteral)
}

public extension Float32 implements FloatingPointLiteralConvertible {
    @intrinsic
    public init(floatingPointLiteral: FloatingPointLiteral)
}

public extension Float64 implements FloatingPointLiteralConvertible {
    @intrinsic
    public init(floatingPointLiteral: FloatingPointLiteral)
}

public extension Bool implements BooleanLiteralConvertible {
    @intrinsic
    public init(booleanLiteral: BooleanLiteral)
}

public extension Char implements CharacterLiteralConvertible {
    @intrinsic
    public init(characterLiteral: CharacterLiteral)
}
