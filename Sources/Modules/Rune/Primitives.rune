/// Builtin Primitive Types

// MARK: - Interfaces

/// Types conforming to Equatable can compare two values of the same type.
public interface Equatable {
    /// Returns whether two values are equal.
    static operator ==(lhs: Self, rhs: Self) -> Bool
}

/// Types conforming to Hashable can provide a stable hash value for use as
/// keys in HashMap and elements in HashSet.
public interface Hashable extends Equatable {
    /// Returns a stable 64-bit hash value for this instance.
    /// Always `Int64` (not platform `Int`) so the value matches the runtime
    /// C ABI (`int64`) and remains full-width on 32-bit targets such as wasm32.
    func hash() -> Int64
}

// MARK: - Signed Integer Types

/// 8-bit signed integer
@builtin
public struct Int8 {
    @runtime
    public init()

    @runtime("rune_string_to_int8")
    public init(value: String)
}

public extension Int8 implements Equatable {
    @intrinsic
    public static operator ==(lhs: Int8, rhs: Int8) -> Bool
}

public extension Int8 implements Hashable {
    @runtime("rune_int8_hash")
    public func hash() -> Int64
}

public extension Int8 implements CustomStringConvertible {
    @runtime("rune_runtime_string_from_int8")
    public func toString() -> String
}

