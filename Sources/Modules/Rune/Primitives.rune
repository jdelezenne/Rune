    public init(integerLiteral: IntegerLiteral)
}

public extension UInt implements IntegerLiteralConvertible {
    @intrinsic
    public init(integerLiteral: IntegerLiteral)
}

public extension Float32 implements FloatingPointLiteralConvertible {
