// Builtin Primitive Types
// This module defines the core types built into the Rune language.
//
// There are no implicit conversions between
// distinct numeric types.
//
// The unlabeled initializer form, e.g. Int32(x), is reserved for value-preserving
// conversion and must reject or trap when the source value is not representable.
// Bit-pattern preserving integer conversion belongs in Int.truncating(x);
// saturating conversion belongs in Int.clamping(x); exact/failable conversion
// belongs in Int.exactly(x).

// MARK: - Signed Integer Types

/// 8-bit signed integer
@builtin
public struct Int8 {
    @runtime("rune_int8_from_string")
    public init(value: String)
}

public extension Int8 implements Equatable {
    @intrinsic
    public static operator ==(lhs: Int8, rhs: Int8) -> Bool
}

public extension Int8 implements Hashable {
    @runtime("rune_int8_hash")
    public func hash() -> Int
}

public extension Int8 implements CustomStringConvertible {
    @runtime("rune_runtime_string_from_int8")
    public func toString() -> String
}

