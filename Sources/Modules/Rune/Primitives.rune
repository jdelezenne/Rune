// MARK: - Other Primitive Types

/// Boolean type
@builtin
public struct Bool {
    @runtime
    public init()
}

public extension Bool implements Equatable {
    @intrinsic
    public static operator ==(lhs: Bool, rhs: Bool) -> Bool
}

public extension Bool implements Hashable {
    @runtime("rune_bool_hash")
    public func hash() -> Int64
}

public extension Bool implements CustomStringConvertible {
    @runtime("rune_runtime_string_from_bool")
    public func toString() -> String
}

/// One Unicode scalar value stored as UTF-8 (1–4 bytes).
@builtin
public struct Char {
    @runtime
    public init()
}

public extension Char implements Equatable {
    @intrinsic
    public static operator ==(lhs: Char, rhs: Char) -> Bool
}

public extension Char implements Hashable {
    /// Returns a stable hash value for this character.
    @runtime("rune_runtime_char_hash")
    public func hash() -> Int64
}

public extension Char implements CustomStringConvertible {
    @runtime("rune_runtime_string_from_char")
    public func toString() -> String
}

public extension Char {
    /// UTF-8 byte length of this character (1–4).
    public utf8Length: Int {
        @runtime("rune_runtime_char_utf8_length")
        get
    }

    /// Unicode scalar value as Int.
    public codePoint: Int {
        @runtime("rune_runtime_char_code_point")
        get
    }
}

// MARK: - Comparable

public extension Int8 implements Comparable {
    @intrinsic
    public static operator <=>(lhs: Int8, rhs: Int8) -> Ordering
}

public extension Int16 implements Comparable {
    @intrinsic
    public static operator <=>(lhs: Int16, rhs: Int16) -> Ordering
}

public extension Int32 implements Comparable {
    @intrinsic
    public static operator <=>(lhs: Int32, rhs: Int32) -> Ordering
}

public extension Int64 implements Comparable {
    @intrinsic
    public static operator <=>(lhs: Int64, rhs: Int64) -> Ordering
}

public extension Int implements Comparable {
    @intrinsic
    public static operator <=>(lhs: Int, rhs: Int) -> Ordering
}

public extension UInt8 implements Comparable {
    @intrinsic
    public static operator <=>(lhs: UInt8, rhs: UInt8) -> Ordering
}

public extension UInt16 implements Comparable {
    @intrinsic
    public static operator <=>(lhs: UInt16, rhs: UInt16) -> Ordering
}

public extension UInt32 implements Comparable {
    @intrinsic
    public static operator <=>(lhs: UInt32, rhs: UInt32) -> Ordering
}

public extension UInt64 implements Comparable {
    @intrinsic
    public static operator <=>(lhs: UInt64, rhs: UInt64) -> Ordering
}

public extension UInt implements Comparable {
    @intrinsic
    public static operator <=>(lhs: UInt, rhs: UInt) -> Ordering
}

public extension Float32 implements Comparable {
    @intrinsic
    public static operator <=>(lhs: Float32, rhs: Float32) -> Ordering
}

public extension Float64 implements Comparable {
    @intrinsic
    public static operator <=>(lhs: Float64, rhs: Float64) -> Ordering
}

public extension Bool implements Comparable {
    @intrinsic
    public static operator <=>(lhs: Bool, rhs: Bool) -> Ordering
}

public extension Char implements Comparable {
    @intrinsic
    public static operator <=>(lhs: Char, rhs: Char) -> Ordering
}

// MARK: - Literal Conversion

public extension Int8 implements IntegerLiteralConvertible {
    @intrinsic
    public init(integerLiteral: IntegerLiteral)
}

public extension Int16 implements IntegerLiteralConvertible {
    @intrinsic
    public init(integerLiteral: IntegerLiteral)
}

public extension Int32 implements IntegerLiteralConvertible {
    @intrinsic
    public init(integerLiteral: IntegerLiteral)
}

public extension Int64 implements IntegerLiteralConvertible {
    @intrinsic
    public init(integerLiteral: IntegerLiteral)
}

public extension Int implements IntegerLiteralConvertible {
    @intrinsic
    public init(integerLiteral: IntegerLiteral)
}

public extension UInt8 implements IntegerLiteralConvertible {
    @intrinsic
    public init(integerLiteral: IntegerLiteral)
}

public extension UInt16 implements IntegerLiteralConvertible {
