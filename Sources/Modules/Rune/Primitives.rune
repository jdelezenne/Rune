// MARK: - Other Primitive Types

/// Boolean type
@builtin
public struct Bool {}

public extension Bool implements Equatable {
    @intrinsic
    public static operator ==(lhs: Bool, rhs: Bool) -> Bool
}

public extension Bool implements Hashable {
    @runtime("rune_bool_hash")
    public func hash() -> Int
}

public extension Bool implements CustomStringConvertible {
    @runtime("rune_runtime_string_from_bool")
    public func toString() -> String
}

/// One Unicode scalar value stored as UTF-8 (1–4 bytes).
@builtin
public struct Char {}

public extension Char implements Equatable {
    @intrinsic
    public static operator ==(lhs: Char, rhs: Char) -> Bool
}

public extension Char implements Hashable {
    /// Returns a stable hash value for this character.
    @runtime("rune_runtime_char_hash")
    public func hash() -> Int
}

public extension Char {
    /// UTF-8 byte length of this character (1–4).
    public utf8Length: Int {
        @runtime("rune_runtime_char_utf8_length")
        get
    }

    /// Unicode scalar value as Int.
    public codePoint: Int {
        @runtime("rune_runtime_char_code_point")
        get
    }
}

// MARK: - Comparable

public extension Int8 implements Comparable {
    @intrinsic
